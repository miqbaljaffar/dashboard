datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id                  String   @id
  name                String
  gender              String
  age                 Int
  cohort              String
  classroom           String
  enrollmentDate      String
  graduationTarget    String
  status              String
  behaviorScore       Int
  attendanceRate      Float
  violationsCount     Int
  assignmentSubmitted Boolean  @default(false)
  quizScore           Int?
  examScore           Int?

  attendance   AttendanceRecord[]
  incidents    BehavioralIncidence[]
  rewards      BehavioralReward[]
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  studentId       String
  date            String
  morning         String
  classSession    String
  eveningRollCall String
  notes           String?

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model BehavioralIncidence {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  severity       String
  pointsDeducted Int
  status         String
  actionTaken    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model BehavioralReward {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  pointsAdded    Int
  description    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

