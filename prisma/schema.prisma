datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id                  String   @id
  name                String
  gender              String
  age                 Int
  classroom           String
  enrollmentDate      String
  graduationTarget    String
  status              String
  behaviorScore       Int
  attendanceRate      Float
  violationsCount     Int

  attendance   AttendanceRecord[]
  incidents    BehavioralIncidence[]
  rewards      BehavioralReward[]
  submissions  AssignmentSubmission[]
  grades       StudentGrade[]
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  studentId       String
  date            String
  morning         String
  classSession    String
  eveningRollCall String
  notes           String?

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  dueDate     String
  
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  assignmentId String
  studentId    String
  submitted    Boolean  @default(false)

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model GradeColumn {
  id        String   @id @default(uuid())
  title     String
  type      String   // "Kuis" or "Ulangan"
  date      String
  
  scores    StudentGrade[]
}

model StudentGrade {
  id            String   @id @default(uuid())
  gradeColumnId String
  studentId     String
  score         Float?     // Nullable for empty input initially

  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradeColumn   GradeColumn @relation(fields: [gradeColumnId], references: [id], onDelete: Cascade)

  @@unique([gradeColumnId, studentId])
}

model BehavioralIncidence {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  severity       String
  pointsDeducted Int
  status         String
  actionTaken    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model BehavioralReward {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  pointsAdded    Int
  description    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

