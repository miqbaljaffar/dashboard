datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id                      String   @id
  name                    String
  gender                  String
  age                     Int
  cohort                  String
  classroom               String
  enrollmentDate          String
  graduationTarget        String
  jlptTarget              String
  currentJlptLevel        String
  jftTarget               String
  sswField                String
  interviewReadiness      String
  emergencyContactName    String
  emergencyContactPhone   String
  relationship            String
  dormBuilding            String
  dormRoom                String
  dormBed                 Int
  status                  String
  behaviorScore           Int
  attendanceRate          Float
  quizAverage             Float
  missingAssignmentsCount Int
  violationsCount         Int
  progressTrend           String

  attendance   AttendanceRecord[]
  dailyReports DailyReport[]
  incidents    BehavioralIncidence[]
  rewards      BehavioralReward[]
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  studentId       String
  date            String
  morning         String
  classSession    String
  eveningRollCall String
  notes           String?

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model QuizTest {
  id               String   @id
  title            String
  type             String
  date             String
  cohort           String
  averageScore     Float
  highestScore     Float
  lowestScore      Float
  passRate         Float
  questionAnalysis Json     // Store array of objects as JSON
  weakTopics       String[]
  strongTopics     String[]
}

model Assignment {
  id             String   @id
  title          String
  type           String
  deadline       String
  cohort         String
  totalStudents  Int
  submittedCount Int
  lateCount      Int
}

model DailyReport {
  id                 String   @id
  studentId          String
  studentName        String
  date               String
  learnedToday       String
  difficultMaterial  String
  studyDurationHours Float
  selfEvaluation     Int
  mood               String
  tomorrowTarget     String
  status             String
  teacherComment     String?
  flaggedReason      String?

  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model DormRoom {
  building         String
  roomNumber       String
  capacity         Int
  occupied         Int
  cleanlinessScore Int
  bedArrangement   String
  hygieneStatus    String
  laundryStatus    String

  @@id([building, roomNumber])
}

model BehavioralIncidence {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  severity       String
  pointsDeducted Int
  status         String
  actionTaken    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model BehavioralReward {
  id             String   @id
  studentId      String
  studentName    String
  date           String
  category       String
  pointsAdded    Int
  description    String

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
